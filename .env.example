# ━━━ DATABASE ━━━
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invitara

# ━━━ AUTH ━━━
JWT_SECRET=change-me-to-a-32-char-minimum-secret-please-and-thanks
SUPERADMIN_EMAILS=you@example.com,admin@example.com

# ━━━ APP ━━━
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_ROOT_DOMAIN=localhost
ENABLE_SUBDOMAINS=false

# ━━━ PAYMENTS (Razorpay — primary for India) ━━━
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ━━━ PAYMENTS (Stripe — for non-INR / NRI customers) ━━━
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ━━━ FILE STORAGE (Vercel Blob) ━━━
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: external image CDN (cloudinary/imgix)
IMAGE_CDN_URL=

# ━━━ EMAIL (Resend) ━━━
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@invitara.com
REPLY_TO_EMAIL=support@invitara.com

# ━━━ CRON ━━━
CRON_SECRET=use-a-long-random-secret-here

# ━━━ RATE LIMITING (Upstash Redis) ━━━
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ━━━ OBSERVABILITY (Sentry) ━━━
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENV=development

# ━━━ OBSERVABILITY (PostHog) ━━━
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ━━━ CAPTCHA (Cloudflare Turnstile) ━━━
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ━━━ WHATSAPP BUSINESS CLOUD API (Meta) ━━━
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ━━━ OTP (MSG91 — primary for India) ━━━
MSG91_AUTH_KEY=
MSG91_SENDER_ID=INVITR
MSG91_OTP_TEMPLATE_ID=

# ━━━ OTP (Twilio — fallback / international) ━━━
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ━━━ SOCIAL OAUTH ━━━
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ━━━ FEATURE FLAGS (GrowthBook) ━━━
GROWTHBOOK_API_HOST=
GROWTHBOOK_CLIENT_KEY=

# ━━━ AI (Optional — Gemini Nano runs client-side in Chrome) ━━━
# Server-side fallback uses algorithmic generation
# GOOGLE_AI_API_KEY=

# ━━━ LOGGING ━━━
LOG_LEVEL=debug
