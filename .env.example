# ━━━ DATABASE ━━━
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invitara

# ━━━ AUTH ━━━
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ━━━ PAYMENTS ━━━
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ━━━ EMAIL (Resend) ━━━
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@invitara.com

# ━━━ AI (Optional — Gemini Nano runs client-side in Chrome) ━━━
# Server-side fallback uses algorithmic generation, no API key needed
# For enhanced server AI, add:
# GOOGLE_AI_API_KEY=...

# ━━━ APP ━━━
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ━━━ CRON ━━━
CRON_SECRET=...
